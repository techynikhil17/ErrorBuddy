  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-levenshtein": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
