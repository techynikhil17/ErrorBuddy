{
  "name": "errbuddy",
  "version": "1.1.0",
  "description": "Your terminal's error best friend",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "eb": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
